#!/usr/bin/env bash
# claude-jira — Claude Code wrapper that auto-logs session time to Jira worklog
#
# Usage:
#   claude-jira [claude options]
#
# Ticket detection (in order):
#   1. Regex match on current git branch (e.g. feature/B2CBE-2083-some-title → B2CBE-2083)
#   2. Interactive prompt if no branch match found
#
# On session exit, logs elapsed time + conversation summary to Jira.

set -euo pipefail

TRACKER_DIR="${HOME}/.claude/jira-tracker"
CONFIG_FILE="${TRACKER_DIR}/config.conf"

# ── Preflight ─────────────────────────────────────────────────────────────────

if [[ ! -f "$CONFIG_FILE" ]]; then
  echo "Error: Jira tracker not configured. Run setup.sh first." >&2
  exit 1
fi

# ── Ticket detection ──────────────────────────────────────────────────────────

get_ticket_from_branch() {
  local branch
  branch=$(git branch --show-current 2>/dev/null || true)
  # Match PROJECT-NUMBER pattern anywhere in the branch name
  if [[ "$branch" =~ ([A-Z][A-Z0-9]+-[0-9]+) ]]; then
    printf '%s' "${BASH_REMATCH[1]}"
  fi
}

TICKET=$(get_ticket_from_branch)

if [[ -z "$TICKET" ]]; then
  echo "No Jira ticket found in current git branch."
  read -rp "Enter Jira ticket ID (e.g., B2CBE-2083) or press Enter to skip: " TICKET
  if [[ -z "$TICKET" ]]; then
    echo "Skipping Jira time tracking."
    exec claude "$@"
  fi
fi

echo "⏱  Tracking time → $TICKET"
export JIRA_TICKET="$TICKET"

# ── Launch Claude Code ────────────────────────────────────────────────────────

claude "$@" || true
